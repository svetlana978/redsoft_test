# Database Configuration
DB_HOST=localhost
DB_HOST_DOCKER=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=test_password
DB_NAME=redsoft
DB_SSLMODE=disable

# Connection Pool Settings
DB_MAX_OPEN_CONNS=50      # Maximum number of open connections
DB_MAX_IDLE_CONNS=25      # Maximum number of idle connections
DB_CONN_MAX_LIFETIME=30m  # Maximum lifetime of a connection
DB_CONN_MAX_IDLE_TIME=10m # Maximum idle time of a connection

# Server Configuration
GRPC_PORT=50051
LOG_LEVEL=info

# External APIs
ENRICH_TIMEOUT=30s
AGIFY_URL=https://api.agify.io
GENDERIZE_URL=https://api.genderize.io
NATIONALIZE_URL=https://api.nationalize.io